# Environment variables template
# Copy this to .env and fill in your values

# Required for evaluation (LLM calls)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HuggingFace token for embedding models
HF_TOKEN=hf_...

# ============================================
# RAG Pipeline (rag_pipeline/config.py)
# ============================================

# Embedding model (HuggingFace)
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Path to save/load FAISS index
# FAISS_INDEX_PATH=./data/faiss_index

# Source documents to index
# DOCS_PATH=./data/input.jsonl

# Chunking settings
# CHUNK_SIZE=350
# CHUNK_OVERLAP=64

# Default retrieval settings
# DEFAULT_TOP_K=5
# MIN_SIMILARITY_SCORE=0.0

# ============================================
# Evaluation (evaluation/config.py)
# ============================================

# RAG API endpoint to evaluate
# API_URL=http://localhost:8000

# Evaluation test set location
# EVAL_DATASET_PATH=evaluation_data/input.jsonl

# LLM model for RAGAS judge metrics
# RAGAS_LLM_MODEL=claude-sonnet-4-5

# LLM model for answer generation (different from judge)
# ANSWER_GENERATOR_LLM_MODEL=claude-haiku-4-5

# Retry settings for rate-limited API calls
# MAX_LLM_RETRIES=5
# INITIAL_RETRY_DELAY_SECONDS=1.0

# Abort evaluation if this many queries fail
# MAX_ALLOWED_FAILURES=10

# Output directory for evaluation results
# RESULTS_DIR=evaluation/results/

# Concurrency limit for API calls
# MAX_CONCURRENT_REQUESTS=2
